# ============================================================
# 複製此檔案為 .env.local 並填入你自己的值
# cp .env.example .env.local
# ============================================================

# Supabase 設定（從 Supabase Dashboard → Settings → API 取得）
NEXT_PUBLIC_SUPABASE_URL=https://你的專案ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase Service Role Key（僅後端使用，請勿洩漏！）
# 從 Supabase → Settings → API Keys → Secret keys 取得
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# 管理員 Email（與 Supabase RLS 設定的管理員 Email 相同）
ADMIN_EMAIL=your-admin@example.com
NEXT_PUBLIC_ADMIN_EMAIL=your-admin@example.com

# Gmail 自動備份設定
# 使用「應用程式密碼」，不是你的 Gmail 登入密碼
# 取得方式：Google 帳號 → 安全性 → 兩步驟驗證 → 應用程式密碼
GMAIL_USER=your-gmail@gmail.com
GMAIL_PASS=xxxx xxxx xxxx xxxx

# 備份接收信箱（可以和 GMAIL_USER 相同）
BACKUP_EMAIL_TO=your-backup-email@gmail.com

# Cron Job 安全密碼（自行設定一串亂碼即可）
CRON_SECRET=your_random_cron_secret_here
